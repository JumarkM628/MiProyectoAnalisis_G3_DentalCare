@{
    ViewBag.Title = "Inicio";
}

<main class="full-width-main">

    <!-- Hero -->
    <section class="hero full-width-section" style="background-image: url('@Url.Content("~/Content/Images/Promocion.png")'); background-size: cover; background-position: center center; background-repeat: no-repeat;">
        <div class="hero-overlay">
            <div class="hero-content">
                <span class="hero-eyebrow">Clínica Dental y Especialidades</span>
                <h1>Sonríe con<br><em>confianza</em></h1>
                <p class="lead">Cuidamos tu salud dental con tecnología moderna y profesionales expertos comprometidos con tu bienestar.</p>
                <div class="hero-actions">
                    <a href="#servicios" class="btn btn-info">Ver servicios</a>
                    <a href="/Home/Contact" class="btn btn-light">Contáctanos</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Services -->
    <section id="servicios" class="services-section full-width-section">
        <div class="container">
            <div class="text-center mb-5">
                <span class="section-label">Lo que ofrecemos</span>
                <h2 class="section-title">Nuestros Servicios</h2>
                <p class="section-subtitle">Todo lo que necesitas para una sonrisa perfecta y una salud bucal óptima</p>
            </div>
            <div class="services-grid">
                <div class="servicio-card">
                    <h4>Limpieza Dental</h4>
                    <p>Eliminamos placa y sarro para mantener tu sonrisa saludable y brillante.</p>
                    <a href="#" class="btn btn-info">Más información</a>
                </div>
                <div class="servicio-card">
                    <h4>Blanqueamiento</h4>
                    <p>Devuelve el brillo natural a tus dientes con nuestros tratamientos avanzados.</p>
                    <a href="#" class="btn btn-info">Más información</a>
                </div>
                <div class="servicio-card">
                    <h4>Ortodoncia</h4>
                    <p>Corrige la posición de tus dientes con tecnología moderna y sin dolor.</p>
                    <a href="#" class="btn btn-info">Más información</a>
                </div>
                <div class="servicio-card">
                    <h4>Endodoncia</h4>
                    <p>Tratamos infecciones y salvamos dientes con procedimientos precisos y seguros.</p>
                    <a href="#" class="btn btn-info">Más información</a>
                </div>
                <div class="servicio-card">
                    <h4>Implantes</h4>
                    <p>Soluciones permanentes para dientes perdidos con implantes de alta calidad.</p>
                    <a href="#" class="btn btn-info">Más información</a>
                </div>
                <div class="servicio-card">
                    <h4>Odontopediatría</h4>
                    <p>Atención especializada y amigable para los más pequeños del hogar.</p>
                    <a href="#" class="btn btn-info">Más información</a>
                </div>
            </div>
        </div>
    </section>

   
</main>
