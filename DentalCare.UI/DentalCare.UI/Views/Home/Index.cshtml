@{
    ViewBag.Title = "Inicio";
}

<main>

    <!-- HERO (IMAGEN PRINCIPAL) -->
    <section class="hero">
        <div class="hero-overlay">
            <div class="hero-content text-center">
                <h1>Sonríe con confianza</h1>
                <p class="lead">Cuidamos tu salud dental con tecnología moderna y profesionales expertos</p>
                <a href="#servicios" class="btn btn-primary btn-lg">Ver servicios</a>
            </div>
        </div>
    </section>

    <!-- SERVICIOS -->
    <section id="servicios" class="container mt-5">
        <div class="text-center mb-5">
            <h2>Nuestros Servicios</h2>
            <p class="text-muted">Todo lo que necesitas para una sonrisa perfecta</p>
        </div>

        <div class="row">

            <div class="col-md-4">
                <div class="card servicio-card">
                    <div class="card-body text-center">
                        <h4>🦷 Limpieza Dental</h4>
                        <p>Eliminamos placa y sarro para mantener tu sonrisa saludable.</p>
                        <a href="#" class="btn btn-outline-primary">Más info</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card servicio-card">
                    <div class="card-body text-center">
                        <h4>😁 Blanqueamiento</h4>
                        <p>Devuelve el brillo natural a tus dientes con nuestros tratamientos.</p>
                        <a href="#" class="btn btn-outline-primary">Más info</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card servicio-card">
                    <div class="card-body text-center">
                        <h4>🪥 Ortodoncia</h4>
                        <p>Corrige la posición de tus dientes con tecnología moderna.</p>
                        <a href="#" class="btn btn-outline-primary">Más info</a>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <!-- SECCION EXTRA -->
    <section class="container mt-5 mb-5">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h2>¿Por qué elegirnos?</h2>
                <p>
                    Contamos con equipo moderno, atención personalizada y años de experiencia en salud dental.
                </p>
                <a href="#" class="btn btn-primary">Agendar cita</a>
            </div>
            <div class="col-md-6">
                <img src="https://images.unsplash.com/photo-1588776814546-ec7e6d1e4b8c"
                     class="img-fluid rounded shadow"
                     alt="Dentista">
            </div>
        </div>
    </section>

</main>