@{
    ViewBag.Title = "Contacto";
}

<main class="full-width-main">

    <!-- Page Hero -->
    <div class="page-hero">
        <h1>Contáctanos</h1>
        <p>Estamos aquí para atenderte. Escríbenos o llámanos y te responderemos a la brevedad.</p>
    </div>

    <!-- Contact Cards -->
    <section class="full-width-section bg-transparent">
        <div class="container">
            <div class="row">

                <!-- Info Card -->
                <div class="col-lg-5 mb-4">
                    <div class="contact-info-card">
                        <h3>Información de contacto</h3>
                        <ul class="contact-details">
                            <li>
                                <span class="contact-icon">📍</span>
                                <div>
                                    <strong>Dirección</strong>
                                    San José, Guadalupe, Mozotal.<br>
                                    Costa Rica
                                </div>
                            </li>
                            <li>
                                <span class="contact-icon">📞</span>
                                <div>
                                    <strong>Teléfono</strong>
                                    <a href="tel:+50688553465">(506) 8855-3465</a>
                                </div>
                            </li>
                            <li>
                                <span class="contact-icon">🕒</span>
                                <div>
                                    <strong>Horario de atención</strong>
                                    Lunes a Viernes: 9:00 – 17:00<br>
                                    Sábados y Domingos: Cerrado
                                </div>
                            </li>
                        </ul>
                        <div class="social-links">
                            <a href="#" aria-label="Instagram" class="social-icon" title="Instagram">📷</a>
                            <a href="#" aria-label="WhatsApp" class="social-icon" title="WhatsApp">💬</a>
                        </div>
                    </div>
                </div>

                <!-- Form Card -->
                <div class="col-lg-7 mb-4">
                    <div class="contact-form-card">
                        <h3>Envíanos un mensaje</h3>
                        <form action="#" method="post">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="nombre" class="form-label">Nombre completo *</label>
                                    <input type="text" class="form-control" id="nombre" name="nombre" placeholder="Tu nombre" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="email" class="form-label">Correo electrónico *</label>
                                    <input type="email" class="form-control" id="email" name="email" placeholder="correo@ejemplo.com" required>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label for="telefono" class="form-label">Teléfono</label>
                                <input type="tel" class="form-control" id="telefono" name="telefono" placeholder="(506) 0000-0000">
                            </div>
                            <div class="mb-3">
                                <label for="asunto" class="form-label">Asunto *</label>
                                <input type="text" class="form-control" id="asunto" name="asunto" placeholder="¿En qué podemos ayudarte?" required>
                            </div>
                            <div class="mb-3">
                                <label for="mensaje" class="form-label">Mensaje *</label>
                                <textarea class="form-control" id="mensaje" name="mensaje" rows="5" placeholder="Escribe tu mensaje aquí..." required></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary">Enviar mensaje</button>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- Map -->
    <section class="full-width-section bg-transparent" style="padding-top: 0;">
        <div class="container">
            <div class="map-container">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3762.418891635186!2d-99.133205384552!3d19.43260768690419!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x85d1f92b3a2d6c4b%3A0x7e5a8b7c9d3e2f1a!2sCentro%20Hist%C3%B3rico%2C%20CDMX!5e0!3m2!1ses!2smx!4v1690000000000!5m2!1ses!2smx"
                        width="100%"
                        height="400"
                        style="border:0;"
                        allowfullscreen=""
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade">
                </iframe>
            </div>
        </div>
    </section>

</main>
