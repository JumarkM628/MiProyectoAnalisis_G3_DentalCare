@{
    ViewBag.Title = "Expediente";
}

<main class="full-width-main">

    <section class="full-width-section bg-transparent">
        <div class="container">
            <div class="row">

                <div class="col-lg-6 mb-4">
                    <div class="contact-form-card">
                        <h3>Datos del paciente</h3>
                        <form>
                            <div class="mb-3">
                                <label class="form-label">Nombre completo</label>
                                <input type="text" class="form-control" placeholder="">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Edad</label>
                                <input type="number" class="form-control">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Telefono</label>
                                <input type="text" class="form-control">
                            </div>
                            <button class="btn btn-primary">Guardar expediente</button>
                        </form>
                    </div>
                </div>

                <div class="col-lg-6 mb-4">
                    <div class="contact-info-card">
                        <h3>Alertas medicas</h3>
                        <ul class="contact-details">
                            <li>Alergia a anestesia</li>
                            <li>Diabetes</li>
                            <li>Hipertension</li>
                        </ul>

                        <div class="mt-3">
                            <textarea class="form-control" placeholder=""></textarea>
                            <button class="btn btn-primary mt-2">Agregar alerta</button>
                        </div>
                    </div>
                </div>

                <div class="col-lg-12 mb-4">
                    <div class="contact-info-card">
                        <h3>Odontograma</h3>
                        <p>Selecciona las piezas dentales afectadas</p>

                        <div class="d-flex flex-wrap gap-2">
                            <button class="btn btn-outline-secondary btn-sm">1</button>
                            <button class="btn btn-outline-secondary btn-sm">2</button>
                            <button class="btn btn-outline-secondary btn-sm">3</button>
                            <button class="btn btn-outline-secondary btn-sm">4</button>
                            <button class="btn btn-outline-secondary btn-sm">5</button>
                            <button class="btn btn-outline-secondary btn-sm">6</button>
                            <button class="btn btn-outline-secondary btn-sm">7</button>
                            <button class="btn btn-outline-secondary btn-sm">8</button>
                            <button class="btn btn-outline-secondary btn-sm">9</button>
                            <button class="btn btn-outline-secondary btn-sm">10</button>
                            <button class="btn btn-outline-secondary btn-sm">11</button>
                            <button class="btn btn-outline-secondary btn-sm">12</button>
                            <button class="btn btn-outline-secondary btn-sm">13</button>
                            <button class="btn btn-outline-secondary btn-sm">14</button>
                            <button class="btn btn-outline-secondary btn-sm">15</button>
                            <button class="btn btn-outline-secondary btn-sm">16</button>
                            <button class="btn btn-outline-secondary btn-sm">17</button>
                            <button class="btn btn-outline-secondary btn-sm">18</button>
                            <button class="btn btn-outline-secondary btn-sm">19</button>
                            <button class="btn btn-outline-secondary btn-sm">20</button>
                            <button class="btn btn-outline-secondary btn-sm">21</button>
                            <button class="btn btn-outline-secondary btn-sm">22</button>
                            <button class="btn btn-outline-secondary btn-sm">23</button>
                            <button class="btn btn-outline-secondary btn-sm">24</button>
                            <button class="btn btn-outline-secondary btn-sm">25</button>
                            <button class="btn btn-outline-secondary btn-sm">26</button>
                            <button class="btn btn-outline-secondary btn-sm">27</button>
                            <button class="btn btn-outline-secondary btn-sm">28</button>
                            <button class="btn btn-outline-secondary btn-sm">29</button>
                            <button class="btn btn-outline-secondary btn-sm">30</button>
                            <button class="btn btn-outline-secondary btn-sm">31</button>
                            <button class="btn btn-outline-secondary btn-sm">32</button>
                        </div>
                    </div>
                </div>

                <div class="col-lg-12 mb-4">
                    <div class="contact-form-card">
                        <h3>Tratamientos</h3>

                        <div class="mb-3">
                            <label class="form-label">Descripcion</label>
                            <input type="text" class="form-control" placeholder="">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Fecha</label>
                            <input type="date" class="form-control">
                        </div>

                        <button class="btn btn-primary">Agregar tratamiento</button>

                        <hr>

                        <h5>Historial</h5>
                        <ul class="contact-details">
                            <li>Limpieza dental - 2026-04-01</li>
                            <li>Extraccion - 2026-03-15</li>
                        </ul>
                    </div>
                </div>

            </div>
        </div>
    </section>

</main>